# MiniMax API key for Vibecoding AI
# Get yours at: https://platform.minimax.io/
MINIMAX_API_KEY=your-minimax-api-key-here

# Optional: Supabase for cloud sync (can also configure in Settings UI)
# Create bucket: vibecoding-projects (public read/write for anon or use RLS)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key